<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<!--
Main layout of the application.

This FXML defines the primary UI structure:
- Top navigation bar
- Center content area for loading pages

The controller responsible for this view is:
org.example.clinic.controllers.MainController
-->

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.clinic.controllers.MainController"
            style="-fx-background-color: #F5F7FA;">

    <!-- Top Navigation Bar-->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="30"
              style="-fx-background-color: #004080; -fx-padding: 15;">

            <Label text="Clinic Management System"
                   style="-fx-font-size: 18px; -fx-text-fill: #ffffff;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Home" onAction="#goHome" styleClass="nav-btn"/>
            <Button text="Doctors" onAction="#goDoctors" styleClass="nav-btn"/>
            <Button text="Patients" onAction="#goPatients" styleClass="nav-btn"/>
            <Button text="Appointments" onAction="#goAppointments" styleClass="nav-btn"/>

        </HBox>
    </top>

    <!-- Main content area-->
    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>