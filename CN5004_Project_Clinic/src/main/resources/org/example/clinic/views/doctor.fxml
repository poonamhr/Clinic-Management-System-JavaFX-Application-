<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<!--
This FXML provides full CRUD functionality for doctor records, including:
- Adding new doctors
- Updating and deleting existing doctors
- Searching and filtering doctor records
- Displaying doctor data in a structured table

The controller responsible for this view is:
org.example.clinic.controllers.DoctorController
-->

<VBox fx:id="root" spacing="20"
      alignment="TOP_CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.clinic.controllers.DoctorController"
      style="-fx-padding: 10 25 25 25;">

    <!-- Title -->
    <HBox alignment="CENTER_LEFT" spacing="10" maxWidth="850">
        <Label text="Manage Doctors 👨‍⚕️"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-padding: 30 0 0 0;"/>
    </HBox>

    <!-- Search bar -->
    <TextField fx:id="searchField"
               promptText="Search doctors..."
               maxWidth="850"/>

    <!-- Form Section-->
    <VBox spacing="25" styleClass="card" maxWidth="980" prefWidth="850">

        <GridPane hgap="40" vgap="18">

            <columnConstraints>
                <ColumnConstraints minWidth="90" prefWidth="100"/>
                <ColumnConstraints minWidth="220" hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="120"/>
                <ColumnConstraints minWidth="90" prefWidth="100"/>
                <ColumnConstraints minWidth="220" hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Row 1 -->
            <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="firstNameField" promptText="Enter first name"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Phone:" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
            <TextField fx:id="phoneField" promptText="10-digit phone"
                       GridPane.rowIndex="0" GridPane.columnIndex="4"/>

            <!-- Row 2 -->
            <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="lastNameField" promptText="Enter last name"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
            <TextField fx:id="emailField" promptText="Enter email"
                       GridPane.rowIndex="1" GridPane.columnIndex="4"/>

            <Separator GridPane.rowIndex="2" GridPane.columnSpan="5"/>

            <!-- Row 3 -->
            <Label text="Specialty:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="specialityBox" promptText="Select specialty"
                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Hours:" GridPane.rowIndex="3" GridPane.columnIndex="3"/>
            <ComboBox fx:id="workingHoursBox" promptText="Select Working Hours"
                      GridPane.rowIndex="3" GridPane.columnIndex="4"/>

            <!-- Buttons -->
            <HBox spacing="15" GridPane.rowIndex="5" GridPane.columnSpan="5"
                  alignment="CENTER_RIGHT">

                <Region HBox.hgrow="ALWAYS"/>

                <Button fx:id="updateBtn"
                        text="Update"
                        onAction="#updateDoctor"
                        styleClass="update-btn"/>

                <Button fx:id="deleteBtn"
                        text="Delete"
                        onAction="#deleteDoctor"
                        styleClass="cancel-btn"/>

                <Button text="Add Doctor"
                        onAction="#addDoctor"
                        styleClass="primary-btn"/>

            </HBox>

        </GridPane>
    </VBox>

    <!-- Doctor Table -->
    <TableView fx:id="doctorTable" styleClass="styled-table"
               maxWidth="980" prefWidth="850"
               VBox.vgrow="ALWAYS">

        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="140"/>
            <TableColumn fx:id="specialityColumn" text="Specialty" prefWidth="140"/>
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="140"/>
            <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="140"/>
            <TableColumn fx:id="hoursColumn" text="Hours" prefWidth="140"/>
        </columns>

    </TableView>

</VBox>